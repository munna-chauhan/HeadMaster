# HeadMaster Configuration Sample
# Copy to config.yml and customize for your setup
# Skills read this directly — missing keys use hardcoded defaults

# ═══════════════════════════════════════════════════════════════════════════════
# PROJECT MANAGEMENT
# ═══════════════════════════════════════════════════════════════════════════════
# Define multiple projects to manage features across different projects.
# Each project can have its own root path, Jira project, and settings.

projects:
  active: platform

  # Example: Multi-repo platform project
  platform:
    name: Platform Services
    root: ../platform                        # Relative to HeadMaster root
    project_key: PLAT
    jira_push: true                          # Push stories to Jira
    coverage_threshold: 80                   # Stricter coverage for platform

  # Example: Legacy monolith project
  legacy-app:
    name: Legacy Application
    root: C:\Projects\LegacyApp              # Absolute path
    project_key: LEG
    jira_push: false                         # No Jira integration
    coverage_threshold: 60                   # Lower bar for legacy code

  # Example: Mobile project
  mobile:
    name: Mobile Apps
    root: ../mobile-apps
    project_key: MOB
    jira_push: true
    coverage_threshold: 75

# ═══════════════════════════════════════════════════════════════════════════════
# PIPELINE BEHAVIOR
# ═══════════════════════════════════════════════════════════════════════════════
# Controls /execute pipeline behavior for all projects

pipeline:
  max_loops: 3                  # Max review iterations before human escalation
                                # (Prevents infinite review loops)

  parallel: false               # Run independent stories simultaneously
                                # true = faster but harder to debug
                                # false = sequential, easier to follow

  interactive: true             # Ask at decision points
                                # true = stop and wait for human approval at gates
                                # false = auto-select best option + log rationale
                                # NOTE: Confusion Clause still applies (always ask if ambiguous)

# ═══════════════════════════════════════════════════════════════════════════════
# ENVIRONMENT VARIABLES (not in config.yml)
# ═══════════════════════════════════════════════════════════════════════════════
# Required for Jira integration (when jira_push: true):
#   ATLASSIAN_DOMAIN=your-org.atlassian.net
#   JIRA_USER_EMAIL=your-email@company.com
#   JIRA_API_TOKEN=your-api-token
#
# Set in your shell profile or .env file (HeadMaster does NOT manage .env)

# ═══════════════════════════════════════════════════════════════════════════════
# PROJECT DIRECTORY STRUCTURE
# ═══════════════════════════════════════════════════════════════════════════════
# HeadMaster creates this structure automatically:
#
# HeadMaster/
# ├── docs/features/{project}/{slug}/
# │   ├── planning/PRD.md
# │   ├── design/TDD*.md
# │   └── breakdown/JIRA_BREAKDOWN.md
# ├── memory/projects/{project}/
# │   ├── features/{slug}/loop_state.json
# │   └── project_repos.json
#
# Project repos (external):
# {project_root}/
# ├── docs/features/{project}/  (optional, project-local features)
# └── <your existing codebase>

# ═══════════════════════════════════════════════════════════════════════════════
# QUICK START
# ═══════════════════════════════════════════════════════════════════════════════
# 1. Copy this file: cp config.yml.sample config.yml
# 2. Edit projects section with your projects
# 3. Set active project: projects.active: <slug>
# 4. (Optional) Set Jira env vars if using jira_push
# 5. Run: /init-feature <slug> to start a new feature

# ═══════════════════════════════════════════════════════════════════════════════
# PERMISSION MODES (configured in .claude/settings.local.json.example)
# ═══════════════════════════════════════════════════════════════════════════════
# Recommended for solo dev:
#   mode: default (auto-approve reads, prompt writes)
#   allow: python scripts/* (HeadMaster automation)
#   deny: git push --force, git reset --hard, git clean -f
