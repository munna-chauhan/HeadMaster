{
  "env": {
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5-20251001",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-7"
  },
  "cleanupPeriodDays": 60,
  "attribution": {
    "commit": "Co-Authored-By: HeadMaster ADLC <noreply@headmaster.dev>",
    "pr": "\n\n🤖 Generated by [HeadMaster ADLC](https://github.com/anthropics/HeadMaster)"
  },
  "permissions": {
    "allow": [
      "Bash(cat)",
      "Read(//tmp/**)",
      "Bash(/path/to/draw.io *)",
      "Bash(where drawio)",
      "Bash(start *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git fetch *)",
      "Bash(git stash *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git merge *)",
      "Bash(git push *)",
      "Bash(git remote *)",
      "Bash(git rev-parse *)",
      "Bash(git show-ref *)",
      "Bash(git ls-files *)",
      "Bash(git config *)",
      "Bash(git pull *)",
      "Bash(python scripts/*)",
      "Bash(python .claude/hooks/*)"
    ],
    "deny": [
      "Bash(git push * --force *)",
      "Bash(git push * -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git checkout -- *)",
      "Bash(git restore *)"
    ],
    "defaultMode": "default"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/activate.py",
            "statusMessage": "Loading project status..."
          },
          {
            "type": "command",
            "command": "python .claude/hooks/feature_context.py",
            "statusMessage": "Loading active feature context..."
          }
        ]
      }
    ]
  },
  "effortLevel": "medium",
  "fastModePerSessionOptIn": true
}
