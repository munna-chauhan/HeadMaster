{
  "permissions": {
    "allow": [
      "Bash(cat)",
      "Read(//tmp/**)",
      "Bash(/path/to/draw.io *)",
      "Bash(where drawio)",
      "Bash(start *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git fetch *)",
      "Bash(git stash *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git merge *)",
      "Bash(git push *)",
      "Bash(git remote *)",
      "Bash(git rev-parse *)",
      "Bash(git show-ref *)",
      "Bash(git ls-files *)",
      "Bash(git config *)",
      "Bash(git pull *)",
      "Bash(python3 scripts/*)",
      "Bash(python .claude/hooks/*)"
    ],
    "deny": [
      "Bash(git push * --force *)",
      "Bash(git push * -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)"
    ],
    "defaultMode": "default",
    "additionalDirectories": [
      "__HOME__"
    ],
    "modeValue": [
      "acceptEdits",
      "bypassPermissions",
      "default",
      "delegate",
      "dontAsk",
      "plan",
      "auto"
    ]
  },
  "enableAllProjectMcpServers": true,
  "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": true,
  "env": {
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "statusLine": "python .claude/hooks/statusline.py",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/session_reset.py",
            "statusMessage": "Resetting session budget..."
          },
          {
            "type": "command",
            "command": "python .claude/hooks/activate.py",
            "statusMessage": "Loading project status..."
          },
          {
            "type": "command",
            "command": "python .claude/hooks/feature_context.py",
            "statusMessage": "Loading active feature context..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/read_compressor.py",
            "statusMessage": "Compressing file read..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/git_guard.py",
            "statusMessage": "Validating git operation..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/write_compressor.py",
            "statusMessage": "Compressing written file..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/token_budget.py"
          },
          {
            "type": "command",
            "command": "python .claude/hooks/mode_tracker.py \"$PROMPT\""
          }
        ]
      }
    ]
  }
}
